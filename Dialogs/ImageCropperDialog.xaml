<Window x:Class="QAMP.Dialogs.ImageCropperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="450"
        Height="550"
        WindowStartupLocation="CenterOwner">
    <Border Background="#1A1A1A"
            CornerRadius="15"
            BorderBrush="#333"
            BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Обрезать обложку"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Border Grid.Row="1"
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#1DB954"
                    BorderThickness="2"
                    ClipToBounds="True">
                <Canvas x:Name="ContainerCanvas"
                        Background="Black"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseWheel="ContainerCanvas_MouseWheel"
                        MouseMove="Canvas_MouseMove">
                    <Image x:Name="SourceImage"
                           Stretch="UniformToFill">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScale"
                                            CenterX="150"
                                            CenterY="150"/>
                        </Image.RenderTransform>
                    </Image>
                </Canvas>
            </Border>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,-25">
                <TextBlock Text="Масштаб"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           FontSize="10"/>
                <Slider x:Name="ZoomSlider"
                        Minimum="0.5"
                        Maximum="3"
                        Value="1"
                        Width="200"
                        Margin="10"
                        ValueChanged="ZoomSlider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Отмена"
                        Click="Cancel_Click"
                        Width="100"
                        Height="35"
                        FontWeight="Bold"
                        Background="#1DB954"
                        Foreground="Black"
                        Margin="0,0,10,0"
                        IsCancel="True"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Готово"
                        Click="Done_Click"
                        Width="100"
                        Height="35"
                        Background="#1DB954"
                        Foreground="Black"
                        FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>