<Window x:Class="QAMP.Windows.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:viewModels="clr-namespace:QAMP.ViewModels"
        xmlns:services="clr-namespace:QAMP.Services"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Настройки QAMP"
        Width="1000"
        Height="800"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="CustomSliderStyle"
               TargetType="Slider">
            <Style.Resources>
                <SolidColorBrush x:Key="SliderThumb.Static.Background"
                                 Color="White"/>
                                 </Style.Resources>
                <Setter Property="Foreground"
                        Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Background"
                        Value="{DynamicResource TertiaryBackgroundBrush}"/>
                <Setter Property="Width"
                        Value="30"/>
                <Setter Property="Margin"
                        Value="5,0"/>
            
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Строка заголовка -->
        <Grid Grid.Row="0"
              Background="{DynamicResource SecondaryBackgroundBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="Настройки QAMP"
                           Foreground="{DynamicResource ForegroundBrush}"
                           FontWeight="Bold"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="BtnClose"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CancelButton_Click">
                    <Path Data="{StaticResource closeGeometry}"
                          Fill="{DynamicResource AccentBrush}"
                          Stretch="Uniform"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Настройки"
                       FontSize="24"
                       FontWeight="Bold"
                       Grid.Row="0"
                       Margin="0,0,0,20"/>

            <!-- Выбор темы -->
            <GroupBox Header="Тема"
                      Grid.Row="1"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <RadioButton x:Name="DarkThemeRadio"
                                 Content="Темная"
                                 GroupName="Theme"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                    <RadioButton x:Name="LightThemeRadio"
                                 Content="Светлая"
                                 GroupName="Theme"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                    <RadioButton x:Name="CustomThemeRadio"
                                 Content="Пользовательская"
                                 GroupName="Theme"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                </StackPanel>
            </GroupBox>

            <!-- Настройка акцентного цвета -->
            <GroupBox Header="Акцентный цвет"
                      Grid.Row="2"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <TextBlock Text="Выберите цвет (HEX):"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="AccentColorTextBox"
                             Width="200"
                             HorizontalAlignment="Left"
                             TextChanged="AccentColorTextBox_TextChanged"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Background="{DynamicResource TertiaryBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="ColorPreview"
                               Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Эквалайзер"
                      Grid.Row="3"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                    <Grid Height="220">  
                <ItemsControl x:Name="EqItemsControl"
                              Margin="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Gain, StringFormat={}{0:0}}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Opacity="0.5"/>

                                <Slider Orientation="Vertical"
                                        Height="150"
                                        Minimum="-12"
                                        Maximum="12"
                                        Value="{Binding Gain, Mode=TwoWay}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="EqSlider_ValueChanged"
                                        Style="{StaticResource CustomSliderStyle}"/>

                                <TextBlock Text="{Binding Frequency}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            </GroupBox>
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Width="100"
                        Height="30"
                        Click="CancelButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="SaveButton"
                        Content="Сохранить"
                        Width="100"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="SaveButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Window>