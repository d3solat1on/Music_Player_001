<Window x:Class="MusicPlayer_by_d3solat1on.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayer_by_d3solat1on"
        xmlns:converters="clr-namespace:MusicPlayer_by_d3solat1on.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="MPM"
        Width="1920"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        FontFamily="GOST type A"
        Loaded="MainWindow_Loaded"
        Background="#141414"
        Foreground="White">

        <Window.Resources>
                <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
                <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
                <converters:NotNullConverter x:Key="NotNullConverter"/>
                <Style x:Key="IconButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter Property="Opacity"
                                                                        Value="0.7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter Property="Opacity"
                                                                        Value="0.5"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>

        <DockPanel LastChildFill="True">
                <!-- Нижняя панель с управлением -->
                <Border DockPanel.Dock="Bottom"
                        Height="220"
                        Background="#0A0A0A"
                        BorderBrush="#333333"
                        BorderThickness="0,1,0,0"
                        Padding="10">
                        <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="YOUR LAST PLAYED TRACK :"
                                           Foreground="#CCCCCC"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <!-- В панель с кнопками управления добавьте: -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,5,0,0">
                                        <Button x:Name="ShuffleButton"
                                                Width="35"
                                                Height="35"
                                                Style="{StaticResource IconButton}"
                                                Click="ShuffleButton_Click"
                                                ToolTip="Перемешивать">
                                        <Image Source ="Resources/shuffle.png"
                                                Stretch="Uniform"
                                                Margin="5"/>
                                        </Button>
                                        <Button x:Name="RepeatButton"
                                                Width="35"
                                                Height="35"
                                                Margin="5,0,0,0"
                                                Style="{StaticResource IconButton}"
                                                Click="RepeatButton_Click"
                                                ToolTip="Повтор">
                                        <Image Source = "Resources/loop.png"
                                                Stretch="Uniform"
                                                Margin="5"/>
                                        </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                        <TextBlock x:Name="LastTrackName"
                                                   Text="NAME"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="5,0"/>
                                        <TextBlock Text="—"
                                                   Foreground="#666666"
                                                   FontSize="18"/>
                                        <TextBlock x:Name="LastTrackExecutor"
                                                   Text="EXECUTOR"
                                                   Foreground="#CCCCCC"
                                                   FontSize="18"
                                                   Margin="5,0"/>
                                        <TextBlock Text="—"
                                                   Foreground="#666666"
                                                   FontSize="18"/>
                                        <TextBlock x:Name="LastTrackAlbum"
                                                   Text="ALBUM"
                                                   Foreground="#CCCCCC"
                                                   FontSize="18"
                                                   Margin="5,0"/>
                                </StackPanel>

                                <TextBlock x:Name="LastTrackData"
                                           Text="MP3, 44kHz, 320 KBPS, JOINT STEREO"
                                           Foreground="#999999"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,5,0,0"/>

                                <Grid Margin="20,10">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="CurrentTimeText"
                                                   Grid.Column="0"
                                                   Text="0:00"
                                                   Foreground="White"
                                                   Margin="5,0"/>
                                        <Slider x:Name="ProgressSlider"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="100"
                                                Value="0"
                                                Thumb.DragStarted="ProgressSlider_DragStarted"
                                                Thumb.DragCompleted="ProgressSlider_DragCompleted"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TotalTimeText"
                                                   Grid.Column="2"
                                                   Text="0:00"
                                                   Foreground="White"
                                                   Margin="5,0"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                        <Button x:Name="PrevButton"
                                                Background="Transparent"
                                                Width="50"
                                                Height="50"
                                                Margin="5"
                                                Style="{StaticResource IconButton}"
                                                Click="PrevButton_Click">
                                                <Image Source="/Resources/fast_rewind.png"
                                                       Stretch="Uniform"
                                                       Margin="5"/>
                                        </Button>
                                        <Button x:Name="PlayPauseButton"
                                                Width="50"
                                                Height="50"
                                                Click="PlayPauseButton_Click"
                                                Background="Transparent"
                                                Style="{StaticResource IconButton}"
                                                BorderThickness="0">
                                                <Image Source="/Resources/play.png"
                                                       Stretch="Uniform"
                                                       Margin="5"/>
                                        </Button>
                                        <Button x:Name="NextButton"
                                                Background="Transparent"
                                                Width="50"
                                                Height="50"
                                                Margin="5"
                                                Style="{StaticResource IconButton}"
                                                Click="NextButton_Click">
                                                <Image Source="/Resources/fast_forward.png"
                                                       Stretch="Uniform"
                                                       Margin="5"/>
                                        </Button>
                                        <Button x:Name="StopButton"
                                                Background="Transparent"
                                                Width="50"
                                                Height="50"
                                                Margin="5"
                                                Style="{StaticResource IconButton}"
                                                Click="StopButton_Click">
                                                <Image Source="/Resources/stop.png"
                                                       Stretch="Uniform"
                                                       Margin="5"/>
                                        </Button>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,10,0,0">
                                        <TextBlock Text="🔈"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"/>
                                        <Slider x:Name="VolumeSlider"
                                                Width="150"
                                                Minimum="0"
                                                Maximum="100"
                                                Value="50"
                                                ValueChanged="VolumeSlider_ValueChanged"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="VolumePercentage"
                                                   Text="50%"
                                                   Foreground="White"
                                                   Width="40"
                                                   Margin="5,0,0,0"/>
                                </StackPanel>
                        </StackPanel>
                </Border>

                <!-- Основная область с тремя колонками -->
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка - плейлисты -->
                        <Border Grid.Column="0"
                                BorderBrush="Gray"
                                BorderThickness="0,0,1,0"
                                Margin="0,0,0,0"
                                Background="#121212">
                                <StackPanel Margin="10">
                                        <DockPanel Margin="0,0,0,10">
                                                <TextBlock Text="ПЛЕЙЛИСТЫ"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>

                                                <StackPanel Orientation="Horizontal"
                                                            DockPanel.Dock="Right">
                                                        <Button x:Name="CreatePlaylistButton"
                                                                Background="Transparent"
                                                                BorderBrush="Transparent"
                                                                Width="40"
                                                                Height="40"
                                                                Click="CreatePlaylistButton_Click"
                                                                ToolTip="Создать плейлист">
                                                                <Image Source="/Resources/add_new_folder.png"
                                                                       Stretch="Uniform"
                                                                       Margin="0,0,5,0"/>
                                                        </Button>
                                                        <Button x:Name="RemovePlaylistButton"
                                                                Background="Transparent"
                                                                BorderBrush="Transparent"
                                                                Width="40"
                                                                Height="40"
                                                                Click="RemovePlaylist_Click"
                                                                ToolTip="Удалить выбранный плейлист"
                                                                IsEnabled="{Binding ElementName=PlaylistsListBox, Path=SelectedItem, Converter={StaticResource NotNullConverter}}">
                                                                <Image Source="/Resources/delete_playlist.png"
                                                                       Stretch="Uniform"/>
                                                        </Button>
                                                        <Button x:Name="AddMusicButton"
                                                                Background="Transparent"
                                                                BorderBrush="Transparent"
                                                                Width="40"
                                                                Height="40"
                                                                Click="AddMusicButton_Click"
                                                                ToolTip="Добавить музыку">
                                                                <Image Source="/Resources/add_music.png"
                                                                       Stretch="Uniform"/>
                                                        </Button>
                                                </StackPanel>
                                        </DockPanel>

                                        <ListBox x:Name="PlaylistsListBox"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 SelectionChanged="PlaylistsListBox_SelectionChanged"
                                                 Height="400">
                                                <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                                <Border BorderBrush="#333333"
                                                                        BorderThickness="0,0,0,1"
                                                                        Padding="8"
                                                                        Margin="0,2"
                                                                        Background="Transparent">
                                                                        <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="50"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <!-- Обложка плейлиста -->
                                                                                <Border Grid.Column="0"
                                                                                        Width="45"
                                                                                        Height="45"
                                                                                        BorderBrush="#444444"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="4"
                                                                                        Background="#222222">
                                                                                        <Grid>
                                                                                                <!-- Изображение (если есть) -->
                                                                                                <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                       Stretch="UniformToFill"
                                                                                                       Margin="2">
                                                                                                        <Image.Style>
                                                                                                                <Style TargetType="Image">
                                                                                                                        <Setter Property="Visibility"
                                                                                                                                Value="Visible"/>
                                                                                                                        <Style.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                             Value="{x:Null}">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Collapsed"/>
                                                                                                                                </DataTrigger>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                             Value="0">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Collapsed"/>
                                                                                                                                </DataTrigger>
                                                                                                                        </Style.Triggers>
                                                                                                                </Style>
                                                                                                        </Image.Style>
                                                                                                </Image>

                                                                                                <!-- Текстовая иконка (если нет изображения) -->
                                                                                                <TextBlock Text="📁"
                                                                                                           FontSize="24"
                                                                                                           HorizontalAlignment="Center"
                                                                                                           VerticalAlignment="Center"
                                                                                                           Foreground="#888888">
                                                                                                        <TextBlock.Style>
                                                                                                                <Style TargetType="TextBlock">
                                                                                                                        <Setter Property="Visibility"
                                                                                                                                Value="Collapsed"/>
                                                                                                                        <Style.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                             Value="{x:Null}">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Visible"/>
                                                                                                                                </DataTrigger>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                             Value="0">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Visible"/>
                                                                                                                                </DataTrigger>
                                                                                                                        </Style.Triggers>
                                                                                                                </Style>
                                                                                                        </TextBlock.Style>
                                                                                                </TextBlock>
                                                                                        </Grid>
                                                                                </Border>

                                                                                <!-- Информация о плейлисте -->
                                                                                <StackPanel Grid.Column="1"
                                                                                            Margin="8,0,0,0"
                                                                                            VerticalAlignment="Center">
                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                   FontWeight="Bold"
                                                                                                   FontSize="14"
                                                                                                   Foreground="White"
                                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                                        <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} треков'}"
                                                                                                   FontSize="10"
                                                                                                   Foreground="#999999"
                                                                                                   Margin="0,2,0,0"/>
                                                                                </StackPanel>
                                                                        </Grid>
                                                                </Border>
                                                        </DataTemplate>
                                                </ListBox.ItemTemplate>
                                        </ListBox>
                                </StackPanel>
                        </Border>

                        <!-- Центральная колонка - треки -->
                        <DataGrid x:Name="TracksDataGrid"
                                  Grid.Column="1"
                                  Background="#141414"
                                  Foreground="White"
                                  RowBackground="#141414"
                                  AlternatingRowBackground="#1A1A1A"
                                  BorderBrush="#333333"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  AutoGenerateColumns="False"
                                  FontSize="14"
                                  Margin="10"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="True"
                                  RowHeaderWidth="0"
                                  VerticalGridLinesBrush="Transparent"
                                  HorizontalGridLinesBrush="Transparent"
                                  MouseDoubleClick="TracksDataGrid_MouseDoubleClick">

                                <DataGrid.Resources>
                                        <!-- Стиль для заголовков колонок -->
                                        <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background"
                                                        Value="#1E1E1E"/>
                                                <Setter Property="Foreground"
                                                        Value="#CCCCCC"/>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="FontSize"
                                                        Value="14"/>
                                                <Setter Property="Height"
                                                        Value="40"/>
                                                <Setter Property="BorderBrush"
                                                        Value="#333333"/>
                                                <Setter Property="BorderThickness"
                                                        Value="0,0,1,1"/>
                                                <Setter Property="HorizontalContentAlignment"
                                                        Value="Left"/>
                                                <Setter Property="Padding"
                                                        Value="10,0,0,0"/>
                                        </Style>

                                        <!-- Стиль для ячеек -->
                                        <Style TargetType="DataGridCell">
                                                <Setter Property="Background"
                                                        Value="Transparent"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Setter Property="BorderBrush"
                                                        Value="Transparent"/>
                                                <Setter Property="VerticalAlignment"
                                                        Value="Center"/>
                                                <Setter Property="Padding"
                                                        Value="10,5,0,5"/>
                                                <Setter Property="FontSize"
                                                        Value="13"/>
                                                <Style.Triggers>
                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                                <Setter Property="Background"
                                                                        Value="#2D2D2D"/>
                                                                <Setter Property="Foreground"
                                                                        Value="White"/>
                                                                <Setter Property="BorderBrush"
                                                                        Value="#007ACC"/>
                                                        </Trigger>
                                                </Style.Triggers>
                                        </Style>

                                        <!-- Стиль для строк -->
                                        <Style TargetType="DataGridRow">
                                                <Setter Property="Background"
                                                        Value="#141414"/>
                                                <Setter Property="MinHeight"
                                                        Value="35"/>
                                                <Style.Triggers>
                                                        <Trigger Property="AlternationIndex"
                                                                 Value="1">
                                                                <Setter Property="Background"
                                                                        Value="#1A1A1A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                                <Setter Property="Background"
                                                                        Value="#2D2D2D"/>
                                                        </Trigger>
                                                </Style.Triggers>
                                        </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                        <DataGridTextColumn Header="NAME"
                                                            Binding="{Binding Name}"
                                                            Width="3*">
                                                <DataGridTextColumn.ElementStyle>
                                                        <Style>
                                                                <Setter Property="TextBlock.Foreground"
                                                                        Value="White"/>
                                                                <Setter Property="TextBlock.Margin"
                                                                        Value="10,0,0,0"/>
                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                        Value="Center"/>
                                                        </Style>
                                                </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="EXECUTOR"
                                                            Binding="{Binding Executor}"
                                                            Width="2*">
                                                <DataGridTextColumn.ElementStyle>
                                                        <Style>
                                                                <Setter Property="TextBlock.Foreground"
                                                                        Value="#CCCCCC"/>
                                                                <Setter Property="TextBlock.Margin"
                                                                        Value="10,0,0,0"/>
                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                        Value="Center"/>
                                                        </Style>
                                                </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="ALBUM"
                                                            Binding="{Binding Album}"
                                                            Width="2*">
                                                <DataGridTextColumn.ElementStyle>
                                                        <Style>
                                                                <Setter Property="TextBlock.Foreground"
                                                                        Value="#CCCCCC"/>
                                                                <Setter Property="TextBlock.Margin"
                                                                        Value="10,0,0,0"/>
                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                        Value="Center"/>
                                                        </Style>
                                                </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="DURATION"
                                                            Binding="{Binding Duration}"
                                                            Width="1*">
                                                <DataGridTextColumn.ElementStyle>
                                                        <Style>
                                                                <Setter Property="TextBlock.Foreground"
                                                                        Value="#999999"/>
                                                                <Setter Property="TextBlock.Margin"
                                                                        Value="10,0,0,0"/>
                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                        Value="Center"/>
                                                        </Style>
                                                </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="BITRATE"
                                                            Binding="{Binding BitrateDisplay}"
                                                            Width="1*">
                                                <DataGridTextColumn.ElementStyle>
                                                        <Style>
                                                                <Setter Property="TextBlock.Foreground"
                                                                        Value="#999999"/>
                                                                <Setter Property="TextBlock.Margin"
                                                                        Value="10,0,0,0"/>
                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                        Value="Center"/>
                                                        </Style>
                                                </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                </DataGrid.Columns>

                                <DataGrid.ContextMenu>
                                        <ContextMenu Background="#2D2D2D"
                                                     Foreground="White">
                                                <MenuItem Header="Удалить из плейлиста"
                                                          Click="RemoveFromPlaylist_Click"
                                                          IsEnabled="{Binding ElementName=PlaylistsListBox, Path=SelectedItem, Converter={StaticResource NotNullConverter}}">
                                                        <MenuItem.Icon>
                                                                <TextBlock Text="🗑️"
                                                                           Margin="3,0"/>
                                                        </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Удалить из библиотеки"
                                                          Click="RemoveFromLibrary_Click">
                                                        <MenuItem.Icon>
                                                                <TextBlock Text="❌"
                                                                           Margin="3,0"/>
                                                        </MenuItem.Icon>
                                                </MenuItem>
                                        </ContextMenu>
                                </DataGrid.ContextMenu>
                        </DataGrid>

                        <!-- Правая колонка - NOW PLAYING -->
                        <Border Grid.Column="2"
                                BorderBrush="Gray"
                                BorderThickness="1,0,0,0"
                                Background="#121212"
                                Margin="0,0,0,0"
                                Padding="20">
                                <StackPanel VerticalAlignment="Top">
                                        <TextBlock Text="NOW PLAYING"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   Margin="0,0,0,30"/>

                                        <Border Width="200"
                                                Height="200"
                                                BorderBrush="LightGray"
                                                BorderThickness="1"
                                                Margin="0,0,0,20">
                                                <TextBlock Text="[COVER]"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="Gray"/>
                                        </Border>

                                        <TextBlock x:Name="CurrentTrackName"
                                                   Text="NAME"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                        <TextBlock x:Name="CurrentTrackExecutor"
                                                   Text="EXECUTOR"
                                                   FontSize="18"
                                                   Foreground="Gray"
                                                   Margin="0,5"/>
                                        <TextBlock x:Name="CurrentTrackAlbum"
                                                   Text="ALBUM"
                                                   FontSize="16"
                                                   Foreground="Gray"
                                                   Margin="0,5"/>
                                        <TextBlock x:Name="CurrentTrackData"
                                                   Text="MP3, 44kHz, 320 KBPS, JOINT STEREO"
                                                   FontSize="12"
                                                   Foreground="DarkGray"
                                                   TextWrapping="Wrap"
                                                   Margin="0,20,0,0"/>
                                </StackPanel>
                        </Border>
                </Grid>
        </DockPanel>
</Window>